# Auto detect text files
* text=auto

# Force LF for web files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Windows scripts
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# Ignore merge conflicts in lock files
package-lock.json merge=ours